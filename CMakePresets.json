{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_GENERATOR_INSTANCE": "C:/Program Files/Microsoft Visual Studio/2022/Community",
        "CMAKE_TOOLCHAIN_FILE": "D:/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_MANIFEST_MODE": "OFF"
      }
    },
    {
      "name": "x64-debug",
      "inherits": "base",
      "architecture": "x64",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows-static",
        "VCPKG_INSTALLED_DIR": "D:/vcpkg/installed"
      }
    },
    {
      "name": "x64-release",
      "inherits": "base",
      "architecture": "x64",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows-static",
        "VCPKG_INSTALLED_DIR": "D:/vcpkg/installed",
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "x86-debug",
      "inherits": "base",
      "architecture": "Win32",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x86-windows-static-jpegview",
        "VCPKG_INSTALLED_DIR": "D:/vcpkg/installed-x86",
        "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/vcpkg-triplets"
      }
    },
    {
      "name": "x86-release",
      "inherits": "base",
      "architecture": "Win32",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x86-windows-static-jpegview",
        "VCPKG_INSTALLED_DIR": "D:/vcpkg/installed-x86",
        "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/vcpkg-triplets",
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    { "name": "x64-debug",   "configurePreset": "x64-debug" },
    { "name": "x64-release", "configurePreset": "x64-release", "configuration": "Release" },
    { "name": "x86-debug",   "configurePreset": "x86-debug" },
    { "name": "x86-release", "configurePreset": "x86-release", "configuration": "Release" }
  ]
}
