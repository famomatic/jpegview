# Normalize line endings to LF in the repository.
# Working tree also uses LF (no CRLF conversion), which keeps diffs clean and
# avoids the mixed CRLF/LF churn seen in earlier commits.
* text=auto eol=lf

# Source, scripts, config, docs - all text, normalized to LF.
*.cpp text eol=lf
*.h   text eol=lf
*.c   text eol=lf
*.hpp text eol=lf
*.txt text eol=lf
*.md  text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.ini text eol=lf
*.tpl text eol=lf
*.rc  text eol=lf
*.bat text eol=lf
*.py  text eol=lf
*.html text eol=lf
*.cmake text eol=lf
*.wxs text eol=lf
*.wxl text eol=lf
*.km  text eol=lf

# Binary assets - never normalize.
*.bmp binary
*.png binary
*.ico binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.rtf binary
*.tga binary
*.psd binary
*.qoi binary
*.nef binary
*.cr2 binary
*.raw binary
*.dll binary
*.lib binary
*.exe binary
*.pdb binary
*.zip binary